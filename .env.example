# Copy to .env to override defaults.
DATABASE_URL=sqlite:///./data/family_tree.db
DATA_DIR=./data

# insightface | face_recognition
FACE_BACKEND=insightface

# InsightFace model pack:
#   buffalo_s ≈ 17 MB  (MobileFaceNet + SCRFD-500MF)  — default
#   buffalo_m ≈ 150 MB
#   buffalo_l ≈ 326 MB (R100 + RetinaFace-R50, highest accuracy)
FACE_MODEL=buffalo_s

# Cosine-similarity thresholds. Tuned for buffalo_s.
# With buffalo_l, raise both ~0.10 (e.g. AUTO=0.88, SUGGEST=0.55).
AUTO_MATCH_THRESHOLD=0.80
SUGGEST_THRESHOLD=0.45

THUMBNAIL_SIZE=360
MAX_UPLOAD_MB=50
